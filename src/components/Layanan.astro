---
const services = [
  {
    icon: 'dine-in',
    title: 'Dine In',
    desc: 'Nikmati langsung di kedai dengan suasana nyaman dan hangat.',
  },
  {
    icon: 'takeaway',
    title: 'Take Away',
    desc: 'Pesan dan bawa pulang. Kemasan aman dan higienis.',
  },
  {
    icon: 'delivery',
    title: 'Delivery',
    desc: 'Antar ke rumah via GoFood, GrabFood, dan ShopeeFood.',
  },
  {
    icon: 'catering',
    title: 'Catering',
    desc: 'Layanan catering untuk acara kantor, ulang tahun, dan gathering.',
  },
];
---

<section id="layanan" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Gradient Banner -->
    <div class="bg-gradient-to-r from-[#FFA94D] to-[#F2711C] rounded-[32px] p-10 lg:p-16 text-white mb-16">
      <div class="max-w-2xl">
        <span class="text-xs font-bold uppercase tracking-widest opacity-80 mb-4 block">Layanan MIRO</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
          Kami Melayani dengan Sepenuh Hati
        </h2>
        <p class="text-white/85 text-lg leading-relaxed">
          Dari makan di tempat hingga catering untuk acara besar — MIRO siap menemani setiap momen Anda.
        </p>
      </div>
    </div>

    <!-- Service Cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map(service => (
        <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 text-center group">
          <div class="w-16 h-16 bg-[#FDE8D8] rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-[#F2711C] transition-colors">
            {service.icon === 'dine-in' && (
              <svg class="w-7 h-7 text-[#F2711C] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            )}
            {service.icon === 'takeaway' && (
              <svg class="w-7 h-7 text-[#F2711C] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
            )}
            {service.icon === 'delivery' && (
              <svg class="w-7 h-7 text-[#F2711C] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
              </svg>
            )}
            {service.icon === 'catering' && (
              <svg class="w-7 h-7 text-[#F2711C] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            )}
          </div>
          <h3 class="text-lg font-bold text-[#241C15] mb-2">{service.title}</h3>
          <p class="text-sm text-[#6B6157] leading-relaxed">{service.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
