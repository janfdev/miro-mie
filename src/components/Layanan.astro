---
const services = [
  { icon: 'home', title: 'Sewa Tempat', desc: 'Tersedia untuk arisan, acara keluarga, dan kumpul bersama teman.' },
  { icon: 'gift', title: 'Menerima Undangan', desc: 'Melayani pesanan untuk katering acara kecil hingga skala besar.' },
  { icon: 'truck', title: 'Delivery', desc: 'Pesan makanan langsung diantar ke lokasi kamu dengan cepat.' },
];
---

<section id="layanan" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="bg-gradient-to-br from-gradient-from to-gradient-to rounded-[40px] p-10 lg:p-16">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white text-center mb-10" style="font-family: var(--font-heading)">
        Layanan MIRO
      </h2>

      <div class="grid md:grid-cols-3 gap-6">
        {services.map(s => (
          <div class="bg-white/15 backdrop-blur-sm rounded-[20px] p-6 text-center text-white border border-white/20">
            <div class="w-14 h-14 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4">
              {s.icon === 'home' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>}
              {s.icon === 'gift' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" /></svg>}
              {s.icon === 'truck' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" /></svg>}
            </div>
            <h3 class="text-lg font-bold mb-2">{s.title}</h3>
            <p class="text-sm text-white/80">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
