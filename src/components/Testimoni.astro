---
import Icon from './Icons.astro';

const testimonials = [
  { name: 'Ibu Sri', role: 'Pelanggan Setia', text: 'Mie Yamin-nya enak banget, porsinya pas dan harganya ramah di kantong. Jadi langganan tiap minggu!', avatar: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80' },
  { name: 'Nugie', role: 'Pelanggan', text: 'Pelayanannya cepat dan ramah, tempatnya juga nyaman buat makan bareng keluarga.', avatar: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&q=80' },
  { name: 'Rina', role: 'Pelanggan', text: 'Rasa kuahnya beda dari mie yamin lain, lebih gurih dan autentik. Recommended banget!', avatar: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&q=80' },
  { name: 'Pak Budi', role: 'Pelanggan Tetap', text: 'Sudah langganan 5 tahun. Rasanya nggak pernah berubah, selalu konsisten. Keluarga saya semua suka.', avatar: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&q=80' },
  { name: 'Dewi', role: 'Mahasiswa', text: 'Harga mahasiswa tapi rasa bintang lima! Mie yamin paling enak se-Cirebon. Wajib coba!', avatar: 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=100&q=80' },
  { name: 'Andi', role: 'Karyawan', text: 'Tempatnya nyaman buat makan siang. Porsinya pas, harganya juga terjangkau. Recommended!', avatar: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&q=80' },
  { name: 'Mbak Lia', role: 'Ibu Rumah Tangga', text: 'Anak-anak suka banget baksonya. Kuahnya gurih, baksonya kenyal. Jadi langganan tiap weekend.', avatar: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&q=80' },
  { name: 'Rizky', role: 'Content Creator', text: 'Es teler-nya segar banget! Cocok buat dessert setelah makan mie. Fotonya juga instagramable.', avatar: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=100&q=80' },
  { name: 'Bu Tika', role: 'Guru', text: 'Sering bawa siswa study tour ke sini. Semua pada suka. Pelayanannya ramah dan cepat.', avatar: 'https://images.unsplash.com/photo-1580489944761-15a19d654956?w=100&q=80' },
];

// Duplicate for seamless loop
const doubled = [...testimonials, ...testimonials];
---

<section id="testimoni" class="bg-cream-soft py-20 lg:py-28 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="text-xs font-bold uppercase tracking-widest text-primary mb-4 block">Testimoni</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading)">
        Apa Kata <span class="text-primary">Pelanggan Kami</span>?
      </h2>
    </div>
  </div>

  <!-- Infinite scroll container -->
  <div class="testi-wrapper">
    <div class="testi-track">
      {doubled.map(item => (
        <div class="testi-card">
          <div class="bg-white rounded-[20px] p-6 shadow-[0_10px_30px_-10px_rgba(36,28,21,0.12)] flex flex-col h-full">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="Star" class="text-star" size={20} strokeWidth={0} />
              ))}
            </div>
            <p class="text-ink-body text-sm leading-relaxed mb-6 flex-1">"{item.text}"</p>
            <div class="flex items-center gap-3 pt-4 border-t border-ink/10 mt-auto">
              <img src={item.avatar} alt={item.name} class="w-10 h-10 rounded-full object-cover flex-shrink-0" loading="lazy" />
              <div>
                <p class="text-sm font-bold text-ink">{item.name}</p>
                <p class="text-xs text-ink-body">{item.role}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testi-wrapper {
    overflow: hidden;
    position: relative;
  }

  .testi-wrapper::before,
  .testi-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .testi-wrapper::before {
    left: 0;
    background: linear-gradient(to right, #FDF3E7, transparent);
  }

  .testi-wrapper::after {
    right: 0;
    background: linear-gradient(to left, #FDF3E7, transparent);
  }

  .testi-track {
    display: flex;
    gap: 1.5rem;
    animation: scroll-testi 40s linear infinite;
    width: max-content;
  }

  .testi-track:hover {
    animation-play-state: paused;
  }

  .testi-card {
    flex-shrink: 0;
    width: 320px;
  }

  @media (min-width: 768px) {
    .testi-card {
      width: 360px;
    }
  }

  @keyframes scroll-testi {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - 0.75rem));
    }
  }
</style>
