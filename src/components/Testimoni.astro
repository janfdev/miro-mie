---
import { testimonials } from '../data/site';
---

<section id="testimoni" class="bg-white py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="text-xs font-bold uppercase tracking-widest text-[#F2711C] mb-4 block">Testimoni</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#241C15] mb-4">
        Apa Kata Mereka?
      </h2>
      <p class="text-[#6B6157] max-w-lg mx-auto">
        Ribuan pelanggan puas. Ini kata mereka tentang MIRO.
      </p>
    </div>

    <!-- Testimonial Grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map(t => (
        <div class="bg-[#FFF8F0] rounded-2xl p-6 hover:shadow-md transition-all duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5 text-[#FFB800]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-[#6B6157] text-sm leading-relaxed mb-6 italic">
            "{t.text}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-[#241C15]/10">
            <div class="w-10 h-10 bg-[#F2711C] rounded-full flex items-center justify-center text-white font-bold text-sm">
              {t.initial}
            </div>
            <div>
              <p class="text-sm font-bold text-[#241C15]">{t.name}</p>
              <p class="text-xs text-[#6B6157]">{t.date}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
