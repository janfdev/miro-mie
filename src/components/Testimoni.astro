---
import { testimonials } from '../data/site';
---

<section id="testimoni" class="py-20 sm:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-xs font-semibold tracking-[0.2em] uppercase text-stone-400">Testimoni</span>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl tracking-tight text-stone-900 mt-3 mb-4">
        Kata Pelanggan Kami
      </h2>
      <p class="text-stone-500 max-w-lg mx-auto">
        Kepuasan pelanggan adalah kebanggaan kami.
      </p>
    </div>

    <!-- Testimonial Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {testimonials.map((t, i) => (
        <div class={`animate-on-scroll delay-${i + 1} bg-stone-50 rounded-xl p-5 border border-stone-100 hover:border-stone-200 transition-colors`}>
          <!-- Stars -->
          <div class="flex gap-0.5 mb-3">
            {Array.from({ length: t.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="text-amber-500"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>

          <p class="text-sm text-stone-600 leading-relaxed mb-4">
            "{t.text}"
          </p>

          <div class="flex items-center gap-2.5 pt-3 border-t border-stone-100">
            <div class="w-8 h-8 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 text-xs font-bold">
              {t.initial}
            </div>
            <div>
              <div class="text-sm font-semibold text-stone-900">{t.name}</div>
              <div class="text-[11px] text-stone-400">{t.date}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>