---
const testimonials = [
  { name: 'Ibu Sri', role: 'Pelanggan Setia', text: 'Mie Yamin-nya enak banget, porsinya pas dan harganya ramah di kantong. Jadi langganan tiap minggu!', avatar: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80' },
  { name: 'Nugie', role: 'Pelanggan', text: 'Pelayanannya cepat dan ramah, tempatnya juga nyaman buat makan bareng keluarga.', avatar: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&q=80' },
  { name: 'Rina', role: 'Pelanggan', text: 'Rasa kuahnya beda dari mie yamin lain, lebih gurih dan autentik. Recommended banget!', avatar: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&q=80' },
  { name: 'Pak Budi', role: 'Pelanggan Tetap', text: 'Sudah langganan 5 tahun. Rasanya nggak pernah berubah, selalu konsisten. Keluarga saya semua suka.', avatar: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&q=80' },
  { name: 'Dewi', role: 'Mahasiswa', text: 'Harga mahasiswa tapi rasa bintang lima! Mie yamin paling enak se-Cirebon. Wajib coba!', avatar: 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=100&q=80' },
  { name: 'Andi', role: 'Karyawan', text: 'Tempatnya nyaman buat makan siang. Porsinya pas, harganya juga terjangkau. Recommended!', avatar: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&q=80' },
  { name: 'Mbak Lia', role: 'Ibu Rumah Tangga', text: 'Anak-anak suka banget baksonya. Kuahnya gurih, baksonya kenyal. Jadi langganan tiap weekend.', avatar: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&q=80' },
  { name: 'Rizky', role: 'Content Creator', text: 'Es teler-nya segar banget! Cocok buat dessert setelah makan mie. Fotonya juga instagramable.', avatar: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=100&q=80' },
  { name: 'Bu Tika', role: 'Guru', text: 'Sering bawa siswa study tour ke sini. Semua pada suka. Pelayanannya ramah dan cepat.', avatar: 'https://images.unsplash.com/photo-1580489944761-15a19d654956?w=100&q=80' },
];

const perPage = 3;
const totalPages = Math.ceil(testimonials.length / perPage);
---

<section id="testimoni" class="bg-cream-soft py-20 lg:py-28 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="text-xs font-bold uppercase tracking-widest text-primary mb-4 block">Testimoni</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading)">
        Apa Kata <span class="text-primary">Pelanggan Kami</span>?
      </h2>
    </div>

    <!-- Carousel wrapper -->
    <div class="relative">
      <!-- Slides container -->
      <div id="testi-track" class="flex transition-transform duration-500 ease-out">
        {Array.from({ length: totalPages }).map((_, pageIdx) => (
          <div class="w-full flex-shrink-0 grid md:grid-cols-3 gap-6 px-2">
            {testimonials.slice(pageIdx * perPage, (pageIdx + 1) * perPage).map(item => (
              <div class="bg-white rounded-[20px] p-6 shadow-[0_10px_30px_-10px_rgba(36,28,21,0.12)] flex flex-col">
                <div class="flex gap-1 mb-4">
                  {Array.from({ length: 5 }).map(() => (
                    <svg class="w-5 h-5 text-star" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  ))}
                </div>
                <p class="text-ink-body text-sm leading-relaxed mb-6 flex-1">"{item.text}"</p>
                <div class="flex items-center gap-3 pt-4 border-t border-ink/10 mt-auto">
                  <img src={item.avatar} alt={item.name} class="w-10 h-10 rounded-full object-cover" loading="lazy" />
                  <div>
                    <p class="text-sm font-bold text-ink">{item.name}</p>
                    <p class="text-xs text-ink-body">{item.role}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>

      <!-- Navigation arrows -->
      <button id="testi-prev" class="absolute top-1/2 -left-4 lg:-left-6 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-md flex items-center justify-center hover:bg-primary hover:text-white transition-colors z-10" aria-label="Sebelumnya">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button id="testi-next" class="absolute top-1/2 -right-4 lg:-right-6 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-md flex items-center justify-center hover:bg-primary hover:text-white transition-colors z-10" aria-label="Selanjutnya">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>

    <!-- Dot indicators -->
    <div class="flex gap-2 justify-center mt-8">
      {Array.from({ length: totalPages }).map((_, i) => (
        <button
          class={`testi-dot w-3 h-3 rounded-full transition-all duration-300 ${i === 0 ? 'bg-primary scale-110' : 'bg-ink/15 hover:bg-ink/30'}`}
          data-index={i}
          aria-label={`Halaman ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('testi-track') as HTMLElement;
  const prevBtn = document.getElementById('testi-prev');
  const nextBtn = document.getElementById('testi-next');
  const dots = document.querySelectorAll('.testi-dot');
  const total = dots.length;
  let current = 0;
  let autoSlide: ReturnType<typeof setInterval>;

  function goTo(page: number) {
    current = (page + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.classList.toggle('bg-primary', i === current);
      d.classList.toggle('scale-110', i === current);
      d.classList.toggle('bg-ink/15', i !== current);
    });
  }

  function startAuto() {
    autoSlide = setInterval(() => goTo(current + 1), 5000);
  }

  function resetAuto() {
    clearInterval(autoSlide);
    startAuto();
  }

  prevBtn?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
  nextBtn?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      goTo(parseInt(dot.getAttribute('data-index') || '0'));
      resetAuto();
    });
  });

  startAuto();
</script>
