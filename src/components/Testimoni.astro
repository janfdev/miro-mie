---
import { testimonials } from '../data/site';
---

<section id="testimoni" class="py-20 sm:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-xs font-semibold tracking-[0.2em] uppercase text-stone-400">Testimoni</span>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl tracking-tight text-stone-900 mt-3 mb-4">
        Kata Pelanggan Kami
      </h2>
      <p class="text-stone-500 max-w-lg mx-auto">
        Kepuasan pelanggan adalah kebanggaan kami.
      </p>
    </div>

    <!-- Testimonial Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {testimonials.map((t, i) => (
        <div class={`animate-on-scroll delay-${i + 1} group relative bg-white rounded-xl p-5 border border-stone-200 hover:border-stone-300 hover:shadow-md transition-all duration-300`}>
          <!-- Quote Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute top-4 right-4 text-stone-200 group-hover:text-stone-300 transition-colors"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>

          <!-- Stars -->
          <div class="flex gap-0.5 mb-3">
            {Array.from({ length: t.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="text-amber-400"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>

          <!-- Text -->
          <p class="text-sm text-stone-600 leading-relaxed mb-5 min-h-[72px]">
            "{t.text}"
          </p>

          <!-- Author with Avatar -->
          <div class="flex items-center gap-3 pt-4 border-t border-stone-100">
            <img
              src={t.avatar}
              alt={t.name}
              class="w-10 h-10 rounded-full border-2 border-stone-100 bg-stone-100"
              loading="lazy"
            />
            <div>
              <div class="text-sm font-semibold text-stone-900">{t.name}</div>
              <div class="text-[11px] text-stone-400">{t.role || 'Pelanggan'}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>