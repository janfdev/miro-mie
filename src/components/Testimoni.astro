---
import { testimonials } from '../data/site';
---

<section id="testimoni" class="py-20 sm:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-primary)]/10 text-[var(--color-primary)] rounded-full text-sm font-semibold mb-4">
        Testimoni
      </span>
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl lg:text-5xl text-[var(--color-dark)] mb-4">
        Kata <span class="text-[var(--color-primary)]">Pelanggan</span> Kami
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Kepuasan pelanggan adalah kebanggaan kami. Ini kata mereka tentang Miro Mie!
      </p>
    </div>

    <!-- Testimonial Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {testimonials.map((t, i) => (
        <div
          class="animate-on-scroll bg-[var(--color-warm-white)] rounded-3xl p-6 border border-[var(--color-warm-cream)] hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
          style={`transition-delay: ${i * 100}ms`}
        >
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <span class="text-[var(--color-primary-light)] text-lg">★</span>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-6">
            "{t.text}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-primary-dark)] flex items-center justify-center text-white font-bold text-sm">
              {t.initial}
            </div>
            <div>
              <div class="font-semibold text-sm text-[var(--color-dark)]">{t.name}</div>
              <div class="text-xs text-[var(--color-text-light)]">{t.date}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
