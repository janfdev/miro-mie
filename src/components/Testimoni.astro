---
const testimonials = [
  { name: 'Ibu Sri', role: 'Pelanggan Setia', text: 'Mie Yamin-nya enak banget, porsinya pas dan harganya ramah di kantong. Jadi langganan tiap minggu!', initial: 'S' },
  { name: 'Nugie', role: 'Pelanggan', text: 'Pelayanannya cepat dan ramah, tempatnya juga nyaman buat makan bareng keluarga.', initial: 'N' },
  { name: 'Rina', role: 'Pelanggan', text: 'Rasa kuahnya beda dari mie yamin lain, lebih gurih dan autentik. Recommended banget!', initial: 'R' },
];
---

<section id="testimoni" class="bg-cream-soft py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="text-xs font-bold uppercase tracking-widest text-primary mb-4 block">Testimoni</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading)">
        Apa Kata <span class="text-primary">Pelanggan Kami</span>?
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map(item => (
        <div class="bg-white rounded-[20px] p-6 shadow-[0_10px_30px_-10px_rgba(36,28,21,0.12)] flex flex-col">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-5 h-5 text-star" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <p class="text-ink-body text-sm leading-relaxed mb-6 flex-1">"{item.text}"</p>
          <div class="flex items-center gap-3 pt-4 border-t border-ink/10 mt-auto">
            <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white font-bold text-sm">{item.initial}</div>
            <div>
              <p class="text-sm font-bold text-ink">{item.name}</p>
              <p class="text-xs text-ink-body">{item.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
