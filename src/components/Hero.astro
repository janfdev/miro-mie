---
---

<section class="relative bg-[#FFF8F0] pt-24 pb-16 lg:pt-32 lg:pb-24 overflow-hidden">
  <!-- Decorative wave -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-[#FDE8D8] rounded-full -translate-y-1/2 translate-x-1/2 opacity-50"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#FDE8D8] rounded-full translate-y-1/2 -translate-x-1/2 opacity-30"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text -->
      <div class="relative z-10">
        <span class="inline-block text-xs font-bold uppercase tracking-widest text-[#F2711C] border border-[#F2711C]/30 rounded-full px-4 py-1.5 mb-6">
          Mie Yamin Miro
        </span>

        <h1 class="text-4xl sm:text-5xl lg:text-[52px] font-extrabold leading-[1.1] text-[#241C15] mb-6">
          Nikmati Sensasi
          <span class="text-[#F2711C] relative">
            Mie Yamin
            <svg class="absolute -bottom-1 left-0 w-full h-3" viewBox="0 0 200 12" fill="none">
              <path d="M2 8C30 2 80 2 100 6C120 10 170 4 198 8" stroke="#F2711C" stroke-width="3" stroke-linecap="round" opacity="0.4"/>
            </svg>
          </span>
          yang Tak Terlupakan
        </h1>

        <p class="text-base lg:text-lg text-[#6B6157] leading-relaxed mb-8 max-w-lg">
          Racikan bumbu khas turun-temurun, mie kenyal, dan topping melimpah. 
          Dibuat fresh setiap hari untuk pengalaman makan yang autentik.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="#menu"
            class="inline-flex items-center gap-2 bg-[#F2711C] hover:bg-[#E0621A] text-white font-semibold px-7 py-3.5 rounded-full transition-colors shadow-lg shadow-[#F2711C]/25"
          >
            Lihat Menu
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="#tentang"
            class="inline-flex items-center gap-2 border-2 border-[#241C15]/15 text-[#241C15] font-semibold px-7 py-3.5 rounded-full hover:border-[#F2711C] hover:text-[#F2711C] transition-colors"
          >
            Cerita Kami
          </a>
        </div>

        <!-- Stats -->
        <div class="flex gap-8 mt-10 pt-8 border-t border-[#241C15]/10">
          <div>
            <p class="text-2xl font-bold text-[#241C15]">10+</p>
            <p class="text-sm text-[#6B6157]">Tahun Pengalaman</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-[#241C15]">50+</p>
            <p class="text-sm text-[#6B6157]">Menu Variasi</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-[#241C15]">4.9</p>
            <p class="text-sm text-[#6B6157]">Rating Google</p>
          </div>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="relative z-10 flex justify-center">
        <div class="relative">
          <div class="absolute inset-0 bg-[#F2711C]/10 rounded-[40px] rotate-3 scale-105"></div>
          <img
            src="https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=600&q=80"
            alt="Mie Yamin Miro — mie kenyal dengan topping ayam cincang dan pangsit renyah"
            class="relative rounded-[40px] shadow-2xl w-full max-w-md lg:max-w-lg object-cover aspect-[4/5]"
            loading="eager"
          />
          <!-- Floating badge -->
          <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-xl p-4 flex items-center gap-3">
            <div class="w-12 h-12 bg-[#FDE8D8] rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-[#F2711C]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-bold text-[#241C15]">Buka Setiap Hari</p>
              <p class="text-xs text-[#6B6157]">09:00 — 21:00</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
