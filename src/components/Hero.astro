---
import Icon from "./Icons.astro";
---

<section class="relative bg-cream py-16 sm:py-24 md:py-50 overflow-hidden">
    <img
        src="/images/bg-frame.png"
        class="absolute inset-0 w-full h-full object-cover z-0"
        alt="bg-hero-section"
    />

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <!-- Left: Text -->
            <div class="relative z-10">
                <span
                    class="inline-block text-xs font-bold uppercase tracking-widest text-white bg-primary border border-primary/30 rounded-full px-4 py-1.5 mb-6"
                >
                    Mie Yamin MIRO
                </span>

                <h1
                    class="text-3xl sm:text-4xl lg:text-[52px] font-extrabold leading-[1.1] text-ink mb-6"
                    style="font-family: var(--font-heading)"
                >
                    Nikmati Sensasi
                    <span class="text-primary relative inline-block">
                        Mie Yamin
                        <svg
                            class="absolute -bottom-1 left-0 w-full h-3"
                            viewBox="0 0 200 12"
                            fill="none"
                        >
                            <path
                                d="M2 8C30 2 80 2 100 6C120 10 170 4 198 8"
                                stroke="#F2711C"
                                stroke-width="3"
                                stroke-linecap="round"
                                opacity="0.4"></path>
                        </svg>
                    </span>
                    {" "} yang Tak Terlupakan
                </h1>

                <p
                    class="text-base lg:text-lg text-ink-body leading-relaxed mb-8 max-w-lg"
                >
                    Menyajikan cita rasa autentik yang dibuat dari bahan pilihan
                    dengan resep khas yang selalu membuat pelanggan kembali
                    lagi.
                </p>

                <div class="flex flex-wrap gap-4">
                    <a
                        href="https://wa.me/6282212339885?text=Halo%20MIRO%2C%20saya%20mau%20pesan"
                        class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-semibold px-7 py-3.5 rounded-full transition-all shadow-[0_8px_20px_-6px_rgba(242,113,28,0.45)] hover:scale-[1.02]"
                    >
                        Pesan Sekarang
                        <Icon name="ArrowRight" class="w-5 h-5" size={20} />
                    </a>
                    <a
                        href="#menu"
                        class="inline-flex items-center gap-2 border-2 border-ink/15 text-ink font-semibold px-7 py-3.5 rounded-full hover:border-primary hover:text-primary transition-colors"
                    >
                        <Icon name="Play" class="w-5 h-5" size={20} />
                        Lihat Menu
                    </a>
                </div>
            </div>

            <!-- Right: Circle Photo -->
            <div class="relative z-10 flex justify-center">
                <div class="relative">
                    <!-- Circle photo -->
                    <div
                        class="w-72 h-72 sm:w-80 sm:h-80 lg:w-[400px] lg:h-[500px] rounded-full"
                    >
                        <img
                            src="/images/hero-section.png"
                            alt="2 mangkuk mie yamin di atas anyaman bambu"
                            class="w-full h-full object-cover"
                            loading="eager"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
