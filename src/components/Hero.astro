---
import Icon from './Icons.astro';
---

<section class="relative bg-cream pt-24 pb-16 lg:pt-32 lg:pb-24 overflow-hidden">
  <!-- Decorative blobs -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary-light rounded-full -translate-y-1/2 translate-x-1/3 opacity-40"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-primary-light rounded-full translate-y-1/2 -translate-x-1/3 opacity-20"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text -->
      <div class="relative z-10">
        <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary border border-primary/30 rounded-full px-4 py-1.5 mb-6">
          Mie Yamin MIRO
        </span>

        <h1 class="text-3xl sm:text-4xl lg:text-[52px] font-extrabold leading-[1.1] text-ink mb-6" style="font-family: var(--font-heading)">
          Nikmati Sensasi
          <span class="text-primary relative inline-block">
            Mie Yamin
            <svg class="absolute -bottom-1 left-0 w-full h-3" viewBox="0 0 200 12" fill="none">
              <path d="M2 8C30 2 80 2 100 6C120 10 170 4 198 8" stroke="#F2711C" stroke-width="3" stroke-linecap="round" opacity="0.4"/>
            </svg>
          </span>
          yang Tak Terlupakan
        </h1>

        <p class="text-base lg:text-lg text-ink-body leading-relaxed mb-8 max-w-lg">
          Menyajikan cita rasa autentik yang dibuat dari bahan pilihan dengan resep khas yang selalu membuat pelanggan kembali lagi.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="https://wa.me/6282212339885?text=Halo%20MIRO%2C%20saya%20mau%20pesan" class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-semibold px-7 py-3.5 rounded-full transition-all shadow-[0_8px_20px_-6px_rgba(242,113,28,0.45)] hover:scale-[1.02]">
            Pesan Sekarang
            <Icon name="ArrowRight" class="w-5 h-5" size={20} />
          </a>
          <a href="#menu" class="inline-flex items-center gap-2 border-2 border-ink/15 text-ink font-semibold px-7 py-3.5 rounded-full hover:border-primary hover:text-primary transition-colors">
            <Icon name="Play" class="w-5 h-5" size={20} />
            Lihat Menu
          </a>
        </div>
      </div>

      <!-- Right: Circle Photo -->
      <div class="relative z-10 flex justify-center">
        <div class="relative">
          <!-- Circle photo -->
          <div class="w-72 h-72 sm:w-80 sm:h-80 lg:w-[400px] lg:h-[400px] rounded-full overflow-hidden border-[10px] border-cream-soft shadow-[0_10px_30px_-10px_rgba(36,28,21,0.12)]">
            <img
              src="https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=600&q=80"
              alt="2 mangkuk mie yamin di atas anyaman bambu"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>

          <!-- Floating: Rating card -->
          <div class="absolute top-4 -left-4 bg-white rounded-xl shadow-[0_10px_30px_-10px_rgba(36,28,21,0.12)] p-3 flex items-center gap-2">
            <Icon name="Star" class="w-5 h-5 text-star" size={20} strokeWidth={0} />
            <span class="text-sm font-bold text-ink">4.3/5.0</span>
          </div>

          <!-- Floating: Sparkle icon -->
          <div class="absolute top-8 -right-2 w-10 h-10 bg-white rounded-full shadow-md flex items-center justify-center">
            <Icon name="Leaf" class="w-5 h-5 text-primary" size={20} />
          </div>

          <!-- Floating: Brand pill -->
          <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-md">
            MIE YAMIN MIRO
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
