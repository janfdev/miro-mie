---
import { menuItems, siteConfig } from '../data/site';

const categories = [...new Set(menuItems.map(item => item.category))];
---

<section id="produk" class="py-20 sm:py-28 bg-[var(--color-warm-white)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-primary)]/10 text-[var(--color-primary)] rounded-full text-sm font-semibold mb-4">
        Menu Kami
      </span>
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl lg:text-5xl text-[var(--color-dark)] mb-4">
        Pilihan <span class="text-[var(--color-primary)]">Produk</span> Favorit
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Empat menu andalan yang jadi favorit pelanggan. Dibuat fresh setiap hari dengan bahan pilihan!
      </p>
    </div>

    <!-- Menu Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {menuItems.map((item, i) => (
        <div
          class="animate-on-scroll group bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-[var(--color-warm-cream)]"
          style={`transition-delay: ${i * 100}ms`}
        >
          <!-- Image Placeholder -->
          <div class="aspect-square bg-gradient-to-br from-[var(--color-warm-cream)] to-orange-50 relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center">
                <span class="text-7xl block mb-2 group-hover:scale-110 transition-transform duration-300">
                  {item.category === 'Mie' ? '🍜' : item.category === 'Baso' ? '🍲' : '🧊'}
                </span>
                <p class="text-xs text-[var(--color-text-light)]">Ganti foto asli</p>
              </div>
            </div>
            {/* Badge */}
            {item.category === 'Mie' && i === 0 && (
              <div class="absolute top-3 left-3 px-3 py-1 bg-[var(--color-secondary)] text-white text-xs font-bold rounded-full shadow-md">
                ⭐ Bestseller
              </div>
            )}
            {/* Category Badge */}
            <div class="absolute top-3 right-3 px-3 py-1 bg-white/90 backdrop-blur-sm text-[var(--color-dark)] text-xs font-semibold rounded-full">
              {item.category}
            </div>
          </div>

          <!-- Content -->
          <div class="p-5">
            <h3 class="font-heading font-bold text-xl text-[var(--color-dark)] mb-2 group-hover:text-[var(--color-primary)] transition-colors">
              {item.name}
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] mb-4 leading-relaxed line-clamp-3">
              {item.description}
            </p>
            <div class="flex items-center justify-between">
              <span class="font-heading font-extrabold text-xl text-[var(--color-primary)]">
                {item.price}
              </span>
              <a
                href={`https://wa.me/${siteConfig.whatsapp}?text=Halo%20Miro%20Mie!%20Saya%20mau%20pesan%20${encodeURIComponent(item.name)}.`}
                target="_blank"
                rel="noopener noreferrer"
                class="p-2.5 bg-[var(--color-accent)] text-white rounded-xl hover:bg-[var(--color-accent-light)] transition-colors shadow-sm hover:shadow-md"
                aria-label={`Pesan ${item.name} via WhatsApp`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom Note -->
    <div class="text-center mt-12 animate-on-scroll">
      <p class="text-sm text-[var(--color-text-light)]">
        * Harga dapat berubah sewaktu-waktu. Hubungi kami untuk info terbaru.
      </p>
    </div>
  </div>
</section>
