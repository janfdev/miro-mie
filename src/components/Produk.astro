---
import { menuItems, siteConfig } from '../data/site';

const imageMap: Record<string, string> = {
  'Mie Yamin': 'https://images.unsplash.com/photo-1555126634-323283e090fa?w=600&q=80&auto=format',
  'Mie Ayam': 'https://images.unsplash.com/photo-1617093727343-374698b1b08d?w=600&q=80&auto=format',
  'Baso': 'https://images.unsplash.com/photo-1529692236671-f1f6cf9683ba?w=600&q=80&auto=format',
  'Es Teler': 'https://images.unsplash.com/photo-1563805042-7684c019e1cb?w=600&q=80&auto=format',
};
---

<section id="produk" class="py-20 sm:py-28 bg-stone-50">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-xs font-semibold tracking-[0.2em] uppercase text-stone-400">Menu Kami</span>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl tracking-tight text-stone-900 mt-3 mb-4">
        Pilihan Favorit Pelanggan
      </h2>
      <p class="text-stone-500 max-w-lg mx-auto">
        Empat menu andalan yang dibuat fresh setiap hari.
      </p>
    </div>

    <!-- Product Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {menuItems.map((item, i) => (
        <div class={`animate-on-scroll delay-${i + 1} group bg-white rounded-xl border border-stone-200 overflow-hidden hover:border-stone-300 hover:shadow-lg hover:-translate-y-1 transition-all duration-300`}>
          <!-- Photo -->
          <div class="aspect-[4/3] overflow-hidden relative">
            <img
              src={imageMap[item.name] || imageMap['Mie Yamin']}
              alt={item.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            {i === 0 && (
              <span class="absolute top-3 left-3 px-2.5 py-1 bg-stone-900/80 backdrop-blur-sm text-white text-[10px] font-semibold tracking-wider uppercase rounded">
                Bestseller
              </span>
            )}
          </div>

          <!-- Content -->
          <div class="p-4">
            <div class="flex items-start justify-between gap-2 mb-1.5">
              <h3 class="font-semibold text-stone-900 text-[15px]">{item.name}</h3>
              <span class="text-sm font-bold text-red-700 whitespace-nowrap">{item.price}</span>
            </div>
            <p class="text-xs text-stone-500 leading-relaxed mb-4 line-clamp-2">{item.description}</p>
            <a
              href={`https://wa.me/${siteConfig.whatsapp}?text=Halo%20Miro%20Mie!%20Saya%20mau%20pesan%20${encodeURIComponent(item.name)}.`}
              target="_blank" rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full px-3 py-2.5 bg-stone-900 text-white rounded-lg text-xs font-semibold shadow-sm hover:bg-red-700 active:bg-red-800 active:scale-[0.97] transition-all duration-150 ease-out"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Pesan via WhatsApp
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>