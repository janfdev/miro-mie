---
import { siteConfig } from "../data/site";
import Icon from "./Icons.astro";
---

<a
    href={`https://wa.me/${siteConfig.whatsapp}?text=Halo%20Miro%20Mie!%20Saya%20mau%20tanya-tanya.`}
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-50 group"
    aria-label="Chat WhatsApp"
>
    <div class="relative">
        <div
            class="absolute inset-0 bg-emerald-500 rounded-full animate-ping opacity-20"
        >
        </div>
        <div
            class="relative w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-emerald-600/25 group-hover:scale-110 transition-all duration-200"
        >
            <img
                src="/whatsapp-icon.svg"
                alt="WhatsApp"
                class="w-6 h-6"
            />
        </div>
    </div>
</a>
