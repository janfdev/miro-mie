---
import { siteConfig } from '../data/site';

const features = [
  { icon: '🥩', title: 'Bahan Segar Setiap Hari', desc: 'Daging, sayuran, dan bumbu dipilih fresh setiap pagi untuk menjamin cita rasa terbaik.' },
  { icon: '👨‍🍳', title: 'Racikan Resep Turun-Temurun', desc: 'Bumbu khas Miro diracik dengan resep warisan keluarga yang sudah teruji waktu.' },
  { icon: '💰', title: 'Harga Terjangkau', desc: 'Makan enak gak harus mahal! Nikmati menu premium dengan harga ramah di kantong.' },
  { icon: '🏠', title: 'Suasana Nyaman & Bersih', desc: 'Tempat makan bersih, nyaman, dan cocok untuk makan bersama keluarga.' },
];
---

<section id="tentang" class="py-20 sm:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-primary)]/10 text-[var(--color-primary)] rounded-full text-sm font-semibold mb-4">
        Tentang Kami
      </span>
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl lg:text-5xl text-[var(--color-dark)] mb-4">
        Cerita di Balik
        <span class="text-[var(--color-primary)]">Miro Mie</span>
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Dimulai dari {siteConfig.year}, kami hadir untuk menyajikan cita rasa mie & baso terbaik dengan sepenuh hati.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Visual -->
      <div class="animate-on-scroll">
        <div class="relative">
          <div class="aspect-[4/3] bg-gradient-to-br from-[var(--color-warm-cream)] to-orange-50 rounded-3xl flex items-center justify-center overflow-hidden">
            <div class="text-center">
              <span class="text-8xl block mb-4">👨‍🍳</span>
              <p class="text-[var(--color-text-muted)] font-medium text-lg">Foto Pemilik / Toko</p>
              <p class="text-sm text-[var(--color-text-light)]">Ganti dengan foto asli</p>
            </div>
          </div>
          <!-- Floating Badge -->
          <div class="absolute -bottom-4 -right-4 bg-[var(--color-primary)] text-white px-6 py-3 rounded-2xl shadow-lg">
            <span class="font-heading font-bold text-lg">Sejak {siteConfig.year}</span>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="animate-on-scroll">
        <blockquote class="text-xl sm:text-2xl font-heading font-semibold text-[var(--color-dark)] mb-8 leading-relaxed border-l-4 border-[var(--color-primary)] pl-6 italic">
          "Kami percaya, makanan yang enak dimulai dari bahan yang segar dan racikan yang tulus."
        </blockquote>

        <p class="text-[var(--color-text-muted)] mb-8 leading-relaxed">
          Miro Mie lahir dari kecintaan terhadap kuliner nusantara. Dengan resep turun-temurun dan bahan pilihan,
          kami menyajikan Mie Yamin, Baso, Mie Ayam, dan Es Teler yang tak hanya lezat, tapi juga menghadirkan
          kenangan rasa yang bikin kembali lagi.
        </p>

        <!-- Features Grid -->
        <div class="grid sm:grid-cols-2 gap-4">
          {features.map((f) => (
            <div class="flex items-start gap-3 p-4 rounded-2xl hover:bg-[var(--color-warm-cream)] transition-colors">
              <span class="text-2xl shrink-0">{f.icon}</span>
              <div>
                <h3 class="font-semibold text-[var(--color-dark)] text-sm">{f.title}</h3>
                <p class="text-xs text-[var(--color-text-muted)] mt-1">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
