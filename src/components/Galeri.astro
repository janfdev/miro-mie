---
const photos = [
  { src: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=700&q=80', alt: 'Suasana dapur MIRO', size: 'large' },
  { src: 'https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=500&q=80', alt: 'Mie Yamin MIRO', size: 'small' },
  { src: 'https://images.unsplash.com/photo-1555126634-323283e090fa?w=500&q=80', alt: 'Mie Ayam MIRO', size: 'small' },
  { src: 'https://images.unsplash.com/photo-1612929633738-8fe44f7ec841?w=500&q=80', alt: 'Bakso MIRO', size: 'small' },
  { src: 'https://images.unsplash.com/photo-1556909114-44e3e70034e2?w=700&q=80', alt: 'Suasana kedai', size: 'large' },
  { src: 'https://images.unsplash.com/photo-1626804475297-41608ea09aeb?w=500&q=80', alt: 'Es Teler MIRO', size: 'small' },
];
---

<section class="bg-white py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="text-xs font-bold uppercase tracking-widest text-primary mb-4 block">Galeri</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading)">Galeri MIRO</h2>
      <p class="text-ink-body mt-3">Momen kebersamaan dan hidangan terbaik kami.</p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[180px] md:auto-rows-[200px]">
      {photos.map((p, i) => (
        <div class={`overflow-hidden rounded-[20px] group cursor-pointer ${
          p.size === 'large'
            ? (i === 0 ? 'col-span-2 row-span-2' : 'col-span-2 row-span-2')
            : 'col-span-1 row-span-1'
        }`}>
          <img
            src={p.src}
            alt={p.alt}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
