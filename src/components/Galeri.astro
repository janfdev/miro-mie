---
const photos = [
  { src: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=700&q=80', alt: 'Suasana dapur MIRO' },
  { src: 'https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=500&q=80', alt: 'Mie Yamin MIRO' },
  { src: 'https://images.unsplash.com/photo-1555126634-323283e090fa?w=500&q=80', alt: 'Mie Ayam MIRO' },
  { src: 'https://images.unsplash.com/photo-1612929633738-8fe44f7ec841?w=500&q=80', alt: 'Bakso MIRO' },
  { src: 'https://images.unsplash.com/photo-1556909114-44e3e70034e2?w=700&q=80', alt: 'Suasana kedai' },
  { src: 'https://images.unsplash.com/photo-1626804475297-41608ea09aeb?w=500&q=80', alt: 'Es Teler MIRO' },
];
---

<section class="bg-white py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="text-xs font-bold uppercase tracking-widest text-primary mb-4 block">Galeri</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading)">Galeri MIRO</h2>
      <p class="text-ink-body mt-3">Momen kebersamaan dan hidangan terbaik kami.</p>
    </div>

    <!-- Bento Grid -->
    <div class="bento-grid">
      {photos.map((p, i) => (
        <div class={`bento-item bento-${i + 1}`}>
          <img src={p.src} alt={p.alt} class="w-full h-full object-cover" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bento-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(3, 180px);
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(3, 200px);
    }
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-rows: repeat(3, 220px);
    }
  }

  .bento-item {
    overflow: hidden;
    border-radius: 20px;
    cursor: pointer;
  }

  .bento-item img {
    transition: transform 0.7s ease;
  }

  .bento-item:hover img {
    transform: scale(1.1);
  }

  /* Item 1: top-left large (2x2) */
  .bento-1 {
    grid-column: span 2;
    grid-row: span 2;
  }

  /* Item 2: top-right small */
  .bento-2 {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* Item 3: mid-right small */
  .bento-3 {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* Item 4: bottom-left small */
  .bento-4 {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* Item 5: bottom-center large (2x1) */
  .bento-5 {
    grid-column: span 2;
    grid-row: span 1;
  }

  /* Item 6: bottom-right small */
  .bento-6 {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* Mobile: all single column, stack vertically */
  @media (max-width: 767px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 200px 180px 180px 180px;
    }

    .bento-1 {
      grid-column: span 2;
      grid-row: span 1;
    }

    .bento-5 {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
</style>
