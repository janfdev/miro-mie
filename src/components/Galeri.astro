---
const photos = [
    {
        src: "/images/grid-1.jpg",
        alt: "Foto Kedai MIRO",
    },
    {
        src: "/images/grid-6.png",
        alt: "Owner MIRO",
    },
    {
        src: "/images/grid-2.png",
        alt: "Kedai MIRO",
    },
    {
        src: "/images/grid-4.png",
        alt: "Suasana kedai",
    },
    {
        src: "/images/grid-5.png",
        alt: "Kedai MIRO",
    },
    {
        src: "/images/grid-3.png",
        alt: "Mie Ayam MIRO, Mie Yamin MIRO",
    },
    {
        src: "/images/grid-7.png",
        alt: "Pelanggan MIRO",
    },
];
---

<section class="bg-white py-24 lg:py-32">
    <div
        class="max-w-7xl flex flex-col items-center justify-center gap-3 mx-auto px-6 lg:px-8"
    >
        <div class="rounded-full w-fit py-0.5 px-4 bg-primary/10">
            <span class="text-xs font-bold uppercase text-primary mb-4"
                >Galeri</span
            >
        </div>
        <div class="text-center mb-16">
            <h2
                class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-ink leading-tight"
                style="font-family: var(--font-heading)"
            >
                Galeri <span class="text-primary">MIRO</span>
            </h2>
        </div>

        <!-- Bento Grid — 7 items -->
        <div class="parent w-full">
            <div class="div1">
                <img src={photos[0].src} alt={photos[0].alt} loading="eager" />
                <div class="bento-overlay">
                    <span class="text-white text-sm font-semibold"
                        >{photos[0].alt}</span
                    >
                </div>
            </div>
            <div class="div2">
                <img src={photos[1].src} alt={photos[1].alt} loading="eager" />
                <div class="bento-overlay">
                    <span class="text-white text-sm font-semibold"
                        >{photos[1].alt}</span
                    >
                </div>
            </div>
            <div class="div3">
                <img src={photos[2].src} alt={photos[2].alt} loading="lazy" />
                <div class="bento-overlay">
                    <span class="text-white text-sm font-semibold"
                        >{photos[2].alt}</span
                    >
                </div>
            </div>
            <div class="div4">
                <img src={photos[3].src} alt={photos[3].alt} loading="lazy" />
                <div class="bento-overlay">
                    <span class="text-white text-sm font-semibold"
                        >{photos[3].alt}</span
                    >
                </div>
            </div>
            <div class="div5">
                <img src={photos[4].src} alt={photos[4].alt} loading="lazy" />
                <div class="bento-overlay">
                    <span class="text-white text-sm font-semibold"
                        >{photos[4].alt}</span
                    >
                </div>
            </div>
            <div class="div6">
                <img src={photos[5].src} alt={photos[5].alt} loading="lazy" />
                <div class="bento-overlay">
                    <span class="text-white text-sm font-semibold"
                        >{photos[5].alt}</span
                    >
                </div>
            </div>
            <div class="div7">
                <img src={photos[6].src} alt={photos[6].alt} loading="lazy" />
                <div class="bento-overlay">
                    <span class="text-white text-sm font-semibold"
                        >{photos[6].alt}</span
                    >
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .parent {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: 200px 200px 200px;
        gap: 8px;
    }

    .parent > div {
        position: relative;
        overflow: hidden;
        border-radius: 1rem;
        cursor: pointer;
    }

    .div1 {
        grid-column: 1;
        grid-row: 1 / 3;
    }
    .div2 {
        grid-column: 1;
        grid-row: 3;
    }
    .div3 {
        grid-column: 2;
        grid-row: 1;
    }
    .div4 {
        grid-column: 2;
        grid-row: 2;
    }
    .div5 {
        grid-column: 2;
        grid-row: 3;
    }
    .div6 {
        grid-column: 3;
        grid-row: 1;
    }
    .div7 {
        grid-column: 3;
        grid-row: 2 / 4;
    }

    .parent img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .parent > div:hover img {
        transform: scale(1.08);
    }

    .bento-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(36, 28, 21, 0.55),
            transparent 50%
        );
        display: flex;
        align-items: flex-end;
        padding: 1.25rem;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .parent > div:hover .bento-overlay {
        opacity: 1;
    }

    @media (max-width: 1023px) {
        .parent {
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: 200px 200px 200px 200px;
        }
        .div1 {
            grid-column: span 2;
            grid-row: 1;
        }
        .div2 {
            grid-column: 1;
            grid-row: 2;
        }
        .div3 {
            grid-column: 2;
            grid-row: 2;
        }
        .div4 {
            grid-column: 1;
            grid-row: 3;
        }
        .div5 {
            grid-column: 2;
            grid-row: 3;
        }
        .div6 {
            grid-column: 1;
            grid-row: 4;
        }
        .div7 {
            grid-column: 2;
            grid-row: 4;
        }
    }

    @media (max-width: 639px) {
        .parent {
            grid-template-columns: 1fr 1fr;
            grid-template-rows: 160px 140px 140px 140px;
        }
        .div1 {
            grid-column: span 2;
            grid-row: 1;
        }
        .div2 {
            grid-column: 1;
            grid-row: 2;
        }
        .div3 {
            grid-column: 2;
            grid-row: 2;
        }
        .div4 {
            grid-column: 1;
            grid-row: 3;
        }
        .div5 {
            grid-column: 2;
            grid-row: 3;
        }
        .div6 {
            grid-column: 1;
            grid-row: 4;
        }
        .div7 {
            grid-column: 2;
            grid-row: 4;
        }
    }
</style>
