---
const slides = [
  { src: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=700&q=80', alt: 'Suasana dapur MIRO — orang memasak mie fresh' },
  { src: 'https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=700&q=80', alt: 'Mie Yamin MIRO — sajian utama' },
  { src: 'https://images.unsplash.com/photo-1555126634-323283e090fa?w=700&q=80', alt: 'Mie Ayam MIRO — best seller' },
];
---

<section id="cerita" class="bg-white py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Carousel -->
      <div class="relative">
        <div class="rounded-[28px] overflow-hidden relative">
          <!-- Slides container -->
          <div id="story-slides" class="relative aspect-[4/3]">
            {slides.map((slide, i) => (
              <div class={`absolute inset-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}>
                <img
                  src={slide.src}
                  alt={slide.alt}
                  class="w-full h-full object-cover"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </div>
            ))}
          </div>
        </div>

        <!-- Chat bubble -->
        <div class="absolute top-4 left-4 bg-white rounded-2xl shadow-[0_10px_30px_-10px_rgba(36,28,21,0.12)] px-4 py-3 max-w-[200px] z-10">
          <p class="text-xs text-ink-body italic">"Resep yang sama sejak hari pertama."</p>
        </div>

        <!-- Founder photo overlay -->
        <div class="absolute -bottom-6 right-8 w-28 h-28 rounded-full border-4 border-white shadow-lg overflow-hidden z-10">
          <img
            src="https://images.unsplash.com/photo-1583394838336-acd977736f90?w=200&q=80"
            alt="Bu Miro — Pendiri"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <!-- Dot indicators -->
        <div class="flex gap-2 mt-8 justify-center">
          {slides.map((_, i) => (
            <button
              class={`story-dot w-3 h-3 rounded-full transition-all duration-300 ${i === 0 ? 'bg-primary scale-110' : 'bg-ink/15 hover:bg-ink/30'}`}
              data-index={i}
              aria-label={`Slide ${i + 1}`}
            ></button>
          ))}
        </div>
      </div>

      <!-- Right: Text -->
      <div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-ink leading-tight mb-6" style="font-family: var(--font-heading)">
          Lebih Dari Sekadar
          <span class="text-primary">Semangkuk Mie</span>
        </h2>
        <p class="text-ink-body leading-relaxed mb-6">
          Berawal dari dapur keluarga, MIRO tumbuh karena satu keyakinan sederhana: setiap orang berhak menikmati semangkuk mie yang dibuat dengan sepenuh hati. Resep kami dirawat dari generasi ke generasi tanpa kompromi — dari pilihan mie, racikan bumbu, hingga penyajian setiap mangkuknya.
        </p>

        <!-- Quote card -->
        <div class="border-l-4 border-primary bg-cream-soft rounded-r-xl p-6">
          <p class="text-ink-body italic leading-relaxed mb-3">
            "Kami tidak hanya menjual mie, kami menghidangkan kenangan yang membuat pelanggan selalu ingin kembali."
          </p>
          <p class="text-sm font-bold text-ink">— Bu Miro, Pendiri</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Auto-slide carousel
  const slides = document.querySelectorAll('#story-slides > div');
  const dots = document.querySelectorAll('.story-dot');
  let current = 0;
  const total = slides.length;

  function goToSlide(index: number) {
    slides.forEach((s, i) => {
      s.classList.toggle('opacity-100', i === index);
      s.classList.toggle('opacity-0', i !== index);
    });
    dots.forEach((d, i) => {
      d.classList.toggle('bg-primary', i === index);
      d.classList.toggle('scale-110', i === index);
      d.classList.toggle('bg-ink/15', i !== index);
    });
    current = index;
  }

  // Auto-slide every 4 seconds
  setInterval(() => {
    goToSlide((current + 1) % total);
  }, 4000);

  // Click dot to navigate
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-index') || '0');
      goToSlide(index);
    });
  });
</script>
