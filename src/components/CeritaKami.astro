---
import Icons from "./Icons.astro";

const stats = [
    {
        icon: "Star",
        label: "4.9/5",
        sub: "Rating Pelanggan",
        desc: "Berdasarkan ulasan positif di Google",
    },
    {
        icon: "ScanFace",
        label: "1000+",
        sub: "Porsi Terjual",
        desc: "Kelezatan yang telah dinikmati oleh pecinta yamin dimana saja.",
    },
    {
        icon: "Smile",
        label: "1000+",
        sub: "Pelanggan Puas",
        desc: "Dari komunitas lokal hingga turis berbagai daerah mencintai MIRO",
    },
    {
        icon: "BadgeCheck",
        label: "Sejak 2020",
        sub: "",
        desc: "Kenyamanan menikmati Mie Yamin hangat langsung di rumah anda",
    },
];

const statsSlide = [
    {
        sub: "5+",
        description: "Tahun Melayani",
    },
    {
        sub: "1000+",
        description: "Porsi Disajikan",
    },
    {
        sub: "1000+",
        description: "Pelanggan Puas",
    },
    {
        sub: "Puluhan",
        description: "Acara Dilayani",
    },
];
---

<section id="cerita" class="bg-white py-20 lg:py-28">
    <div
        class="max-w-7xl flex flex-col items-center justify-center mx-auto px-6 lg:px-8"
    >
        <div
            class="rounded-full w-fit py-1 px-4 bg-primary/20 mx-auto lg:mx-0 mb-12"
        >
            <span
                class="text-sm text-primary uppercase font-extrabold"
                style="font-family: var(--font-heading)"
            >
                Cerita Kami
            </span>
        </div>

        <!-- Slides — each has its own layout -->
        <div id="story-slides" class="relative">
            <!-- Slide 1: image + text side by side -->
            <div class="slide grid lg:grid-cols-2 gap-12 items-center">
                <div class="rounded-[28px] overflow-hidden aspect-square">
                    <img
                        src="/images/about-us.png"
                        alt="Suasana dapur MIRO"
                        class="w-full h-full object-cover"
                        loading="eager"
                    />
                </div>
                <div>
                    <h2
                        class="text-3xl sm:text-4xl lg:text-6xl font-extrabold text-ink mb-2"
                        style="font-family: var(--font-heading)"
                    >
                        Lebih Dari Sekadar
                    </h2>
                    <h3
                        class="text-3xl sm:text-4xl lg:text-6xl font-extrabold text-primary mb-6"
                    >
                        Semangkuk Mie
                    </h3>
                    <p class="text-ink-body leading-relaxed mb-8">
                        Berawal dari dapur keluarga, MIRO tumbuh karena satu
                        keyakinan sederhana: setiap orang berhak menikmati
                        semangkuk mie yang dibuat dengan sepenuh hati. Resep
                        kami dirawat dari generasi ke generasi tanpa kompromi —
                        dari pilihan mie, racikan bumbu, hingga penyajian setiap
                        mangkuknya.
                    </p>
                    <div class="bg-primary/10 rounded-2xl p-6">
                        <p class="text-ink-body italic leading-relaxed mb-3">
                            "Kami tidak hanya menjual mie, kami menghidangkan
                            kenangan yang membuat pelanggan selalu ingin
                            kembali."
                        </p>
                        <p class="text-sm font-bold text-primary">
                            — Bu Miro, Pendiri
                        </p>
                    </div>
                </div>
            </div>

            <!-- Slide 2: two images stacked vertical + text -->
            <div class="slide hidden grid lg:grid-cols-5 gap-6 items-center">
                <div class="lg:col-span-3 flex flex-col items-center">
                    <div
                        class="rounded-[28px] overflow-hidden w-4/5 sm:w-3/4 lg:w-[350px]"
                    >
                        <img
                            src="/images/slide-2-2.png"
                            alt="Proses masak"
                            class="w-full h-auto"
                            loading="lazy"
                        />
                    </div>
                    <div
                        class="rounded-[28px] overflow-hidden w-3/4 sm:w-2/3 lg:w-[350px]"
                    >
                        <img
                            src="/images/slide-2-1.png"
                            alt="Mie Yamin MIRO"
                            class="w-full h-auto"
                            loading="lazy"
                        />
                    </div>
                </div>
                <div class="lg:col-span-2">
                    <div
                        class="rounded-full w-fit py-1 px-4 bg-primary/20 mx-auto lg:mx-0 mb-12"
                    >
                        <span
                            class="text-sm text-primary uppercase font-extrabold"
                            style="font-family: var(--font-heading)"
                        >
                            Perjalanan Kami
                        </span>
                    </div>

                    <h2
                        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-ink mb-2"
                        style="font-family: var(--font-heading)"
                    >
                        Tumbuh Bersama
                    </h2>
                    <h3
                        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-primary mb-6"
                    >
                        Kepercayaan Pelanggan
                    </h3>
                    <p class="text-ink-body leading-relaxed mb-8">
                        Perjalanan MIRO dimulai dari usaha sederhana dengan satu
                        tujuan, menyajikan kehangatan dalam setiap mangkuk mie.
                        Dari gerobak kecil hingga kini menjadi pilihhan
                        keluarga, dedikasi kami pada resep warisan tetap tidak
                        akan pernah berubah.
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        {
                            statsSlide.map((slide) => (
                                <div class="bg-gray-100 rounded-2xl p-5">
                                    <span class="text-3xl text-primary font-extrabold">
                                        {slide.sub}
                                    </span>
                                    <p class="text-ink-body">
                                        {slide.description}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Slide 3: text only, no image -->
            <div class="slide hidden">
                <div class="grid lg:grid-cols-2 grid-cols-1">
                    <div class="max-w-3xl mx-auto py-12">
                        <span
                            class="text-sm text-primary uppercase font-extrabold"
                            style="font-family: var(--font-heading)"
                        >
                            Pencapaian Kami
                        </span>

                        <h2
                            class="text-3xl sm:text-4xl lg:text-6xl font-extrabold text-ink mb-4"
                            style="font-family: var(--font-heading)"
                        >
                            Kualitas Yang Mendapatkan
                        </h2>
                        <h3
                            class="text-3xl sm:text-4xl lg:text-6xl font-extrabold text-primary mb-8"
                        >
                            Kepercayaan
                        </h3>

                        <p
                            class="text-ink-body leading-relaxed text-lg max-w-lg mb-10"
                        >
                            Konsistensi dalam menjaga kualitas makanan dan
                            pelayanan telah membawa MIRO mendapatkan kepercayaan
                            dari pelanggan selama bertahun-tahun. Setiap
                            pencapaian yang diraih menjadi motivasi untuk terus
                            menghadirkan pengalaman kuliner terbaik bagi setiap
                            pelanggan.
                        </p>
                        <div class="flex items-center gap-3">
                            <button
                                class="bg-primary font-bold cursor-pointer text-white py-2 px-4 rounded-full"
                            >
                                Lihat Menu Favorit
                            </button>
                            <button
                                class="border font-bold border-primary cursor-pointer py-2 px-4 rounded-full text-primary bg-transparent"
                            >
                                Baca Kisah Kami
                            </button>
                        </div>
                    </div>
                    <div class="grid md:grid-cols-2 grid-cols-1 gap-4">
                        {
                            stats.map((s) => (
                                <div class="flex flex-col items-center justify-center gap-2 rounded-2xl p-4 text-center border border-ink/10">
                                    <Icons
                                        name={s.icon}
                                        class="text-primary"
                                        size={28}
                                    />
                                    <h3 class="text-lg font-bold text-ink">
                                        {s.label}
                                    </h3>
                                    <span class="text-xs font-semibold text-primary uppercase tracking-wide">
                                        {s.sub}
                                    </span>
                                    <p class="text-sm text-ink-body">
                                        {s.desc}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Dot indicators -->
        <div class="flex gap-2 mt-10 justify-center">
            <button
                class="story-dot w-3 h-3 rounded-full bg-primary scale-110 transition-all duration-300"
                data-index="0"
                aria-label="Slide 1"></button>
            <button
                class="story-dot w-3 h-3 rounded-full bg-ink/15 hover:bg-ink/30 transition-all duration-300"
                data-index="1"
                aria-label="Slide 2"></button>
            <button
                class="story-dot w-3 h-3 rounded-full bg-ink/15 hover:bg-ink/30 transition-all duration-300"
                data-index="2"
                aria-label="Slide 3"></button>
        </div>
    </div>
</section>

<script>
    const slides = document.querySelectorAll("#story-slides > .slide");
    const dots = document.querySelectorAll(".story-dot");
    let current = 0;
    const total = slides.length;

    function goToSlide(index: number) {
        slides.forEach((s, i) => {
            s.classList.toggle("hidden", i !== index);
        });
        dots.forEach((d, i) => {
            d.classList.toggle("bg-primary", i === index);
            d.classList.toggle("scale-110", i === index);
            d.classList.toggle("bg-ink/15", i !== index);
        });
        current = index;
    }

    setInterval(() => {
        goToSlide((current + 1) % total);
    }, 7000);

    dots.forEach((dot) => {
        dot.addEventListener("click", () => {
            const index = parseInt(dot.getAttribute("data-index") || "0");
            goToSlide(index);
        });
    });
</script>
