---
import { siteConfig } from '../data/site';
---

<section class="py-16 sm:py-24 bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-primary-dark)] relative overflow-hidden">
  <!-- Decorative -->
  <div class="absolute top-0 left-0 w-full h-full opacity-10">
    <div class="absolute top-4 left-[10%] text-6xl">🍜</div>
    <div class="absolute bottom-4 right-[10%] text-6xl">🍲</div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-8xl">❄️</div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="animate-on-scroll">
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl lg:text-5xl text-white mb-6">
        Laper? Langsung Aja! 🤤
      </h2>
      <p class="text-lg sm:text-xl text-white/80 mb-10 max-w-2xl mx-auto">
        Pesan sekarang via WhatsApp, dan nikmati kelezatan Mie Yamin, Baso, Mie Ayam, dan Es Teler dari Miro Mie!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`https://wa.me/${siteConfig.whatsapp}?text=Halo%20Miro%20Mie!%20Saya%20mau%20pesan.`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-white text-[var(--color-primary)] rounded-2xl font-bold text-lg hover:bg-[var(--color-warm-cream)] transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Pesan Sekarang via WhatsApp
        </a>
        <a
          href="#produk"
          class="inline-flex items-center justify-center gap-2 px-8 py-5 bg-white/10 text-white border-2 border-white/30 rounded-2xl font-bold text-lg hover:bg-white/20 transition-all backdrop-blur-sm"
        >
          🍜 Lihat Menu Dulu
        </a>
      </div>
    </div>
  </div>
</section>
