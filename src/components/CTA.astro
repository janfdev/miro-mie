---
import { siteConfig } from '../data/site';
---

<section class="py-20 sm:py-28 bg-stone-900">
  <div class="max-w-3xl mx-auto px-6 text-center animate-on-scroll">
    <h2 class="font-heading font-bold text-3xl sm:text-4xl tracking-tight text-white mb-4">
      Laper? Langsung Aja.
    </h2>
    <p class="text-stone-400 mb-8 max-w-md mx-auto leading-relaxed">
      Pesan sekarang via WhatsApp, nikmati kelezatan Mie Yamin, Baso, Mie Ayam, dan Es Teler.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href={`https://wa.me/${siteConfig.whatsapp}?text=Halo%20Miro%20Mie!%20Saya%20mau%20pesan.`}
        target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-white text-stone-900 rounded-lg font-semibold text-sm shadow-sm hover:bg-stone-100 active:bg-stone-200 active:scale-[0.97] transition-all duration-150 ease-out"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Pesan Sekarang
      </a>
      <a href="#produk" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-stone-800 text-white rounded-lg font-medium text-sm border border-stone-700 hover:bg-stone-700 active:bg-stone-600 active:scale-[0.97] transition-all duration-150 ease-out">
        Lihat Menu
      </a>
    </div>
  </div>
</section>