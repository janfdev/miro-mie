---
import Icon from "./Icons.astro";
---

<section class="">
    <div class="bg-primary py-16 px-8 text-center text-white">
        <h2
            class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4"
            style="font-family: var(--font-heading)"
        >
            Lapar? Pesan Mie Favoritmu Sekarang!
        </h2>
        <p class="text-white/85 text-lg mb-8 max-w-xl mx-auto">
            Pesan melalui WhatsApp dan nikmati cita rasa khas MIRO.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
            <a
                href="https://wa.me/6282313338851"
                class="inline-flex items-center gap-2 bg-white text-primary font-bold px-8 py-4 rounded-full hover:bg-cream transition-all hover:scale-[1.02] shadow-lg"
            >
                Pesan Sekarang
                <Icon name="ArrowRight" class="w-5 h-5" size={20} />
            </a>
            <a
                href="#menu"
                class="inline-flex items-center gap-2 border-2 border-white/50 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/10 transition-colors"
            >
                Lihat Menu
            </a>
        </div>
    </div>
</section>
