---
import Icon from './Icons.astro';

const menuItems = [
  {
    num: '01',
    tag: 'Menu Andalan',
    name: 'Mie Yamin',
    desc: 'Mie kenyal dengan bumbu yamin khas, dipadukan ayam cincang gurih, sawi segar, dan taburan bawang renyah. Disajikan bersama kuah hangat berisi pangsit dan bakso untuk melengkapi setiap suapan.',
    checks: ['Mie Homemade', 'Ayam Cincang Melimpah', 'Kuah Pangsit dan Bakso'],
    image: '/images/mie-yamin.png',
    side: 'left',
  },
  {
    num: '02',
    tag: 'Best Seller',
    name: 'Mie Ayam',
    desc: 'Nikmati kelezatan mie ayam khas dengan potongan ayam berbumbu yang empuk dan kaya rasa. Dipadukan mie kenyal serta sayuran segar untuk menciptakan hidangan yang memuaskan setiap kali disantap.',
    checks: ['Bumbu Khas Rumahan', 'Ayam Kecap Empuk', 'Sayuran Segar'],
    image: '/images/mie-ayam-produk.png',
    side: 'right',
  },
  {
    num: '03',
    tag: 'Favorit Keluarga',
    name: 'Bakso Spesial',
    desc: 'Semangkuk bakso hangat dengan tekstur yang kenyal dan kuah kaldu yang gurih meresap. Disajikan dengan pelengkap pilihan untuk menghadirkan cita rasa yang selalu dirindukan.',
    checks: ['Bakso Pilihan', 'Kuah Gurih Hangat', 'Rasa Autentik'],
    image: '/images/bakso-spesial.png',
    side: 'left',
  },
  {
    num: '04',
    tag: 'Penutup Segar',
    name: 'Es Teler',
    desc: 'Perpaduan alpukat lembut, kelapa muda, nangka, dan sirup santan gula merah yang menyegarkan. Penutup sempurna setelah menyantap semangkuk mie.',
    checks: ['Alpukat Segar', 'Kelapa Muda', 'Santan Gula Merah'],
    image: '/images/es-teler.png',
    side: 'right',
  },
];
---

<section id="menu" class="bg-cream-soft py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col items-center justify-center text-center mb-16 gap-4">
        <div class="rounded-full w-fit py-1 px-4 bg-primary/10">
            <span class="text-xs font-bold uppercase text-primary mb-4 ">Menu Unggulan</span>
        </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-ink mb-4" style="font-family: var(--font-heading)">
        Setiap Sajian, <span class="text-primary">Sebuah Cerita</span>
      </h2>
      <p class="text-ink-body max-w-lg mx-auto">
        Bukan sekadar menu — tiap hidangan diracik untuk momen yang layak dikenang.
      </p>
    </div>

    <!-- Menu Items -->
    <div class="space-y-16 lg:space-y-24">
      {menuItems.map(item => (
        <div class="grid lg:grid-cols-2 gap-10 items-center">
          <!-- Image -->
          <div class={`relative ${item.side === 'right' ? 'lg:order-2' : ''}`}>
            <div class="rounded-[28px] overflow-hidden">
              <img
                src={item.image}
                alt={item.name}
                class="w-full aspect-4/3 object-cover"
                loading="lazy"
              />
            </div>
            <!-- Price badge -->
            <!-- <div class="absolute bottom-4 left-4 bg-white/95 rounded-full px-4 py-1.5 text-sm font-bold text-ink shadow-[0_10px_30px_-10px_rgba(36,28,21,0.12)]">
              {item.price}
            </div> -->
          </div>

          <!-- Text -->
          <div class={item.side === 'right' ? 'lg:order-1' : ''}>
              <div class="flex mb-3 items-center justify-center gap-2 bg-white rounded-full px-4 py-1.5 text-sm font-bold text-ink shadow-[0_10px_30px_-10px_rgba(36,28,21,0.12)] w-fit">
                  <span class="text-black text-xs">{item.num}</span>
                  <span class="text-xs font-bold text-primary uppercase tracking-wider">
                  {item.tag}
                </span>
              </div>
            <h3 class="text-2xl lg:text-3xl font-extrabold text-ink mb-4" style="font-family: var(--font-heading)">
              {item.name}
            </h3>
            <p class="text-ink-body leading-relaxed mb-5">
              {item.desc}
            </p>

            <!-- Checklist -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-6">
              {item.checks.map(check => (
                <div class="flex items-center justify-center gap-2 bg-white rounded-full w-fit py-2 px-4">
                  <Icon name="Check" class="text-green-500 shrink" size={20} />
                  <span class="text-sm text-ink">{check}</span>
                </div>
              ))}
            </div>

            <a href={`https://wa.me/6282212339885?text=Halo%20MIRO%2C%20saya%20mau%20pesan%20${encodeURIComponent(item.name)}`}
              class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-full transition-all hover:shadow-[0_8px_20px_-6px_rgba(242,113,28,0.45)] hover:scale-[1.02]">
              Pesan {item.name}
              <Icon name="ArrowRight" class="w-4 h-4" size={16} />
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
