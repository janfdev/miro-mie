---
import { siteConfig } from '../data/site';

const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-950 text-stone-400">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <span class="font-heading font-bold text-white text-xl">{siteConfig.name}</span>
        <p class="text-sm leading-relaxed mt-3 text-stone-500">{siteConfig.description}</p>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Navigasi</h4>
        <ul class="space-y-2">
          <li><a href="#beranda" class="text-sm text-stone-500 hover:text-white transition-colors">Beranda</a></li>
          <li><a href="#tentang" class="text-sm text-stone-500 hover:text-white transition-colors">Tentang</a></li>
          <li><a href="#produk" class="text-sm text-stone-500 hover:text-white transition-colors">Produk</a></li>
          <li><a href="#testimoni" class="text-sm text-stone-500 hover:text-white transition-colors">Testimoni</a></li>
          <li><a href="#kontak" class="text-sm text-stone-500 hover:text-white transition-colors">Kontak</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Kontak</h4>
        <ul class="space-y-2">
          <li class="text-sm text-stone-500">{siteConfig.address}</li>
          <li class="text-sm text-stone-500">{siteConfig.phone}</li>
          <li class="text-sm text-stone-500">{siteConfig.hours}</li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Sosial Media</h4>
        <ul class="space-y-2">
          <li><a href="#" class="text-sm text-stone-500 hover:text-white transition-colors">{siteConfig.instagram}</a></li>
          <li><a href="#" class="text-sm text-stone-500 hover:text-white transition-colors">{siteConfig.tiktok}</a></li>
          <li><a href="#" class="text-sm text-stone-500 hover:text-white transition-colors">{siteConfig.facebook}</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-stone-800/50 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-stone-600">&copy; {currentYear} {siteConfig.name}. All rights reserved.</p>
      <p class="text-xs text-stone-700">Dibuat dengan hati untuk UMKM Indonesia</p>
    </div>
  </div>
</footer>