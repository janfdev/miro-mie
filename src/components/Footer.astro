          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-[#F2711C] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Buka Setiap Hari: 09.00 — 21.00
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[#C9CDD6]">&copy; 2024 MIRO — Mie Yamin & Ayam. All rights reserved.</p>
