      <!-- Menu -->
      <div>
        <h4 class="text-white font-bold text-sm mb-4">Menu</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#menu" class="hover:text-[#F2711C] transition-colors">Mie Yamin</a></li>
          <li><a href="#menu" class="hover:text-[#F2711C] transition-colors">Mie Ayam</a></li>
          <li><a href="#menu" class="hover:text-[#F2711C] transition-colors">Bakso</a></li>
          <li><a href="#menu" class="hover:text-[#F2711C] transition-colors">Es Teler</a></li>
        </ul>
      </div>

      <!-- Kontak -->
      <div>
        <h4 class="text-white font-bold text-sm mb-4">Kontak</h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-[#F2711C] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Jl. Contoh No. 123, Kota Anda
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-[#F2711C] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
