---
import Icon from "./Icons.astro";

type SocialMedia = {
    icon: string;
    title: string;
    name: string;
    href?: string;
};
export const socialMedia: SocialMedia[] = [
    {
        icon: "Radio",
        title: "Instagram",
        name: "@mieyaminmiro",
    },
    {
        icon: "Mic",
        title: "Tiktok",
        name: "@mieyaminmiro",
    },
    {
        icon: "PhoneIncoming",
        title: "Whatsapp",
        name: "+62 823 1333 8851",
    },
    {
        icon: "BadgeCheck",
        title: "Facebook",
        name: "Mie Yamin Miro",
    },
];
---

<footer class="bg-navy text-navy-text py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid md:grid-cols-4 gap-10 mb-12">
            <!-- Brand -->
            <div>
                <div class="flex items-center gap-2 mb-4">
                    <img
                        src="/images/Logo-miro.png"
                        alt="MIRO"
                        class="w-20 h-20"
                    />
                </div>
                <p class="text-sm leading-relaxed">
                    Mie Yamin MIRO menghadirkan citra rasa khas yang selalu
                    melekat di hati pelanggan kami.
                </p>
                <p
                    class="text-sm italic text-primary font-semibold mt-2 leading-relaxed"
                >
                    "Rasa Khas, Selalu Melekat"
                </p>
            </div>

            <!-- Menu -->
            <div>
                <h4 class="text-white font-bold text-sm mb-4">Menu</h4>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a href="#" class="hover:text-primary transition-colors"
                            >Beranda</a
                        >
                    </li>
                    <li>
                        <a
                            href="#tentang"
                            class="hover:text-primary transition-colors"
                            >Tentang</a
                        >
                    </li>
                    <li>
                        <a
                            href="#menu"
                            class="hover:text-primary transition-colors"
                            >Produk</a
                        >
                    </li>
                    <li>
                        <a
                            href="#testimoni"
                            class="hover:text-primary transition-colors"
                            >Testimoni</a
                        >
                    </li>
                    <li>
                        <a
                            href="#kontak"
                            class="hover:text-primary transition-colors"
                            >Kontak</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Layanan -->
            <div>
                <h4 class="text-white font-bold text-sm mb-4">Layanan</h4>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a
                            href="#layanan"
                            class="hover:text-primary transition-colors"
                            >Delivery</a
                        >
                    </li>
                    <li>
                        <a
                            href="#layanan"
                            class="hover:text-primary transition-colors"
                            >Catering</a
                        >
                    </li>
                    <li>
                        <a
                            href="#layanan"
                            class="hover:text-primary transition-colors"
                            >Sewa Tempat</a
                        >
                    </li>
                    <li>
                        <a
                            href="#layanan"
                            class="hover:text-primary transition-colors"
                            >Dine In</a
                        >
                    </li>
                    <li>
                        <a
                            href="#layanan"
                            class="hover:text-primary transition-colors"
                            >Event Orders</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Sosial -->
            <div>
                <h4 class="text-white font-bold text-sm mb-4">Sosial Media</h4>
                <ul class="space-y-2 text-sm">
                    {
                        socialMedia.map((item) => {
                            return (
                                <li class="">
                                    <a
                                        href={item.href}
                                        class="flex items-center gap-2 cursor-pointer hover:text-primary transition-colors"
                                    >
                                        <div class="flex items-center bg-primary/20 p-1 rounded-md">
                                            <Icon
                                                class="text-primary"
                                                size={14}
                                                name={item.icon}
                                            />
                                        </div>
                                        <span>{item.title}</span>
                                    </a>
                                </li>
                            );
                        })
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="border-t border-white/10 pt-6 text-center">
        <p class="text-xs">&copy; 2026 MIRO. All rights reserved.</p>
    </div>
</footer>
