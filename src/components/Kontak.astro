---
import Icon from "./Icons.astro";
---

<section id="kontak" class="bg-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-14">
            <span
                class="text-xs font-bold uppercase tracking-widest text-primary mb-4 block"
                >Hubungi Kami</span
            >
            <h2
                class="text-3xl sm:text-4xl font-extrabold text-ink"
                style="font-family: var(--font-heading)"
            >
                Pesan & Kunjungi MIRO
            </h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-8 items-stretch">
            <!-- Map -->
            <div
                class="rounded-[28px] overflow-hidden min-h-[300px] lg:min-h-[400px]"
            >
                <iframe
                    src="https://www.google.com/maps/embed?pb=!4v1784733754745!6m8!1m7!1sUcJg0JpYxQhlBYgUSopOJg!2m2!1d-6.742212326448239!2d108.4928468541914!3f324.65441209466854!4f-14.813382141550221!5f0.7820865974627469"
                    width="100%"
                    height="100%"
                    style="border:0"
                    allowfullscreen
                    loading="lazy"
                    title="Lokasi MIRO"></iframe>
            </div>

            <!-- Info Card -->
            <div class="bg-primary rounded-[28px] p-8 text-white gap-5">
                <div class="flex flex-col items-center justify-center">
                    <h3
                        class="text-2xl font-bold"
                        style="font-family: var(--font-heading)"
                    >
                        Informasi Kedai
                    </h3>
                </div>

                <div class="flex flex-col gap-4 mt-5">
                    <div class="flex items-start gap-3">
                        <div
                            class="backdrop-blur-2xl bg-white/20 p-3 rounded-2xl"
                        >
                            <Icon
                                name="MapPin"
                                class="shrink mt-0.5 text-white"
                                size={20}
                            />
                        </div>
                        <div class="flex flex-col gap-2">
                            <h4 class="uppercase text-white/80 text-xs">
                                Alamat
                            </h4>
                            <p class="text-sm text-white/90">
                                Jl. Fasyahillah No.45, Wolubawuc, Kec. Bantar,
                                Kabupaten Cirebon (Depan Kampus 2 UMC)
                            </p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div
                            class="backdrop-blur-2xl bg-white/20 p-3 rounded-2xl"
                        >
                            <Icon
                                name="Clock"
                                class="shrink mt-0.5 text-white"
                                size={20}
                            />
                        </div>
                        <div class="flex flex-col gap-2">
                            <h4 class="uppercase text-white/80 text-xs">
                                Jam Buka
                            </h4>
                            <p class="text-sm text-white/90">
                                Setiap Hari, 09:00 — 17:00 WIB
                            </p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div
                            class="backdrop-blur-2xl bg-white/20 p-3 rounded-2xl"
                        >
                            <Icon
                                name="Phone"
                                class="shrink mt-0.5 text-white"
                                size={20}
                            />
                        </div>
                        <div class="flex flex-col gap-2">
                            <h4 class="uppercase text-white/80 text-xs">
                                Telepon
                            </h4>
                            <p class="text-sm text-white/90">
                                +62 823-1333-8851
                            </p>
                        </div>
                    </div>
                </div>

                <div class="mt-10 flex flex-col gap-2">
                    <a
                        href="https://wa.me/6282313338851"
                        class="mt-auto flex items-center justify-center gap-5 bg-white text-primary font-bold text-center py-3.5 rounded-full hover:bg-cream transition-colors"
                    >
                        <img src="/whatsapp-icon.svg" class="w-7 h-7" />
                        <span class="">Pesan via WhatsApp Sekarang</span>
                    </a>
                    <a
                        href="https://www.tiktok.com/@mieyaminmiro?_r=1&_t=ZS-98DWLV6O1jd"
                        class="mt-auto flex items-center justify-center gap-10 bg-white text-primary font-bold text-center py-3.5 rounded-full hover:bg-cream transition-colors"
                    >
                        <img src="/tiktok-icon-light.svg" class="w-7 h-7" />
                        <span class="">Pesan via TikTok Sekarang</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
