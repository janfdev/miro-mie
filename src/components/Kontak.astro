---
import Icon from './Icons.astro';
---

<section id="kontak" class="bg-white py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="text-xs font-bold uppercase tracking-widest text-primary mb-4 block">Hubungi Kami</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading)">Pesan & Kunjungi MIRO</h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 items-stretch">
      <!-- Map -->
      <div class="rounded-[28px] overflow-hidden min-h-[400px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3962.0!2d108.0!3d-6.0!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwMDAnMDAuMCJTIDEwOMKwMDAnMDAuMCJF!5e0!3m2!1sid!2sid!4v1"
          width="100%" height="100%" style="border:0; min-height: 400px;" allowfullscreen loading="lazy"
          title="Lokasi MIRO"
        ></iframe>
      </div>

      <!-- Info Card -->
      <div class="bg-primary rounded-[28px] p-8 text-white flex flex-col gap-5">
        <h3 class="text-xl font-bold" style="font-family: var(--font-heading)">Informasi Kedai</h3>

        <div class="flex items-start gap-3">
          <Icon name="MapPin" class="flex-shrink-0 mt-0.5 text-white" size={20} />
          <p class="text-sm text-white/90">Jl. Fasyahillah No.45, Wolubawuc, Kec. Bantar, Kabupaten Cirebon (Depan Kampus 2 UMC)</p>
        </div>

        <div class="flex items-start gap-3">
          <Icon name="Clock" class="flex-shrink-0 mt-0.5 text-white" size={20} />
          <p class="text-sm text-white/90">Setiap hari, 09:00 – 17:00 WIB</p>
        </div>

        <div class="flex items-start gap-3">
          <Icon name="Phone" class="flex-shrink-0 mt-0.5 text-white" size={20} />
          <p class="text-sm text-white/90">+62 822-1233-9885</p>
        </div>

        <div class="flex gap-3">
          <a href="#" class="bg-white/20 rounded-full px-4 py-2 text-xs font-semibold hover:bg-white/30 transition-colors">TikTok @mieyaminmiro</a>
          <a href="#" class="bg-white/20 rounded-full px-4 py-2 text-xs font-semibold hover:bg-white/30 transition-colors">Instagram</a>
        </div>

        <a href="https://wa.me/6282212339885" class="mt-auto bg-white text-primary font-bold text-center py-3.5 rounded-full hover:bg-cream transition-colors">
          Pesan via WhatsApp Sekarang
        </a>
      </div>
    </div>
  </div>
</section>
