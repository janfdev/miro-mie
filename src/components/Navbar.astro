---
const navItems = [
  { label: 'Beranda', href: '#' },
  { label: 'Tentang', href: '#cerita' },
  { label: 'Produk', href: '#menu' },
  { label: 'Layanan', href: '#layanan' },
  { label: 'Testimoni', href: '#testimoni' },
  { label: 'Kontak', href: '#kontak' },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm transition-shadow duration-300">
  <nav class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-2">
        <span class="bg-primary text-white text-xs font-bold px-3 py-1 rounded-full">miro</span>
        <span class="text-ink font-bold text-lg tracking-tight hidden sm:block">Mie Yamin & Ayam</span>
      </a>

      <!-- Desktop Menu -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          <a href={item.href} class="text-sm font-medium text-ink-body hover:text-primary transition-colors">
            {item.label}
          </a>
        ))}
      </div>

      <!-- CTA -->
      <a href="https://wa.me/6282212339885" class="hidden sm:inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-all hover:shadow-[0_8px_20px_-6px_rgba(242,113,28,0.45)]">
        Pesan Sekarang
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>

      <!-- Mobile -->
      <button id="mobile-btn" class="lg:hidden p-2 text-ink" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden pb-4">
      <div class="flex flex-col gap-3">
        {navItems.map((item) => (
          <a href={item.href} class="text-sm font-medium text-ink-body hover:text-primary py-2">{item.label}</a>
        ))}
        <a href="https://wa.me/6282212339885" class="inline-flex items-center justify-center gap-2 bg-primary text-white text-sm font-semibold px-5 py-2.5 rounded-full mt-2">
          Pesan Sekarang
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('shadow-sm');
    } else {
      navbar?.classList.remove('shadow-sm');
    }
  });
</script>
