---
import Icon from "./Icons.astro";

type NavItem = {
    label: string;
    href: string;
};

const navItems: NavItem[] = [
    { label: "Beranda", href: "#" },
    { label: "Tentang", href: "#cerita" },
    { label: "Produk", href: "#menu" },
    { label: "Layanan", href: "#layanan" },
    { label: "Testimoni", href: "#testimoni" },
    { label: "Kontak", href: "#kontak" },
];
---

<header
    id="navbar"
    class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm transition-shadow duration-300 mt-2 mx-2 rounded-full shadow-sm lg:mt-5 lg:mx-20"
>
    <nav class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 lg:h-20">
            <!-- Logo -->
            <div>
                <img
                    src="/images/Logo-miro.png"
                    alt="Miro Mie Logo"
                    class="h-10 w-auto"
                />
            </div>

            <!-- Desktop Menu -->
            <div class="hidden lg:flex items-center gap-8">
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            class="text-sm font-medium text-ink-body hover:text-primary border-b-0 hover:border-b-2 hover:border-b-primary transition-colors"
                        >
                            {item.label}
                        </a>
                    ))
                }
            </div>

            <a
                href="https://wa.me/6282212339885"
                class="hidden sm:inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-all hover:shadow-[0_8px_20px_-6px_rgba(242,113,28,0.45)]"
            >
                Pesan Sekarang
                <Icon name="ArrowRight" class="w-4 h-4" size={16} />
            </a>

            <!-- Mobile -->
            <button
                id="mobile-btn"
                class="lg:hidden p-2 text-ink"
                aria-label="Menu"
            >
                <Icon name="Menu" class="w-6 h-6" size={24} />
            </button>
        </div>

        <div id="mobile-menu" class="hidden lg:hidden pb-4">
            <div class="flex flex-col gap-3">
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            class="text-sm font-medium text-ink-body hover:text-primary py-2"
                        >
                            {item.label}
                        </a>
                    ))
                }
                <a
                    href="https://wa.me/6282212339885"
                    class="inline-flex items-center justify-center gap-2 bg-primary text-white text-sm font-semibold px-5 py-2.5 rounded-full mt-2"
                >
                    Pesan Sekarang
                </a>
            </div>
        </div>
    </nav>
</header>

<script>
    const btn = document.getElementById("mobile-btn");
    const menu = document.getElementById("mobile-menu");
    btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));

    const navbar = document.getElementById("navbar");
    window.addEventListener("scroll", () => {
        if (window.scrollY > 20) {
            navbar?.classList.add("shadow-sm");
        } else {
            navbar?.classList.remove("shadow-sm");
        }
    });
</script>
